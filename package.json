{
  "name": "@0xkobold/pi-codebase-wiki",
  "version": "0.7.2",
  "type": "module",
  "description": "Keeps a wiki for your code that updates itself — reads your git history and docs so you can ask questions about your codebase",
  "keywords": [
    "pi-package",
    "wiki",
    "codebase",
    "cli",
    "agent",
    "kapy"
  ],
  "main": "./src/index.ts",
  "bin": {
    "wiki": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./core": {
      "import": "./src/core/index.ts",
      "types": "./src/core/index.ts"
    }
  },
  "files": [
    "src/",
    "skills/",
    "web/"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills/codebase-wiki/SKILL.md"
    ]
  },
  "dependencies": {
    "@moikapy/kapy": "0.3.0",
    "sql.js": "^1.14.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.71.1",
    "@sinclair/typebox": "^0.34.49"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "rm -rf dist && tsc",
    "test": "bun test"
  },
  "license": "MIT",
  "devDependencies": {
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
